# MongoDB Connection
API_URL=mongodb+srv://username:password@cluster.mongodb.net/ashboard?retryWrites=true&w=majority

# JWT Secrets (generate secure random strings)
JWT_SECRET=your-jwt-secret-key-min-32-characters-long
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-min-32-chars

# Redis Connection (optional, for caching)
REDIS_URL=redis://localhost:6379

# MQTT Broker (for IoT devices)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# App Configuration
# (Do not set NODE_ENV — Next.js/Vercel manage it automatically.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (transactional email — password resets, etc.)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Ashboard <noreply@yourdomain.com>

# Optional: gate for auth.checkEmailExists debug procedure
# Set this to enable the procedure; clients must pass `x-debug-token` matching this value.
# DEBUG_TOKEN=some-long-random-string

# OAuth — Google
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${NEXT_PUBLIC_APP_URL}/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED=false

# OAuth — GitHub
# Create an OAuth app at https://github.com/settings/developers
# Authorization callback URL: ${NEXT_PUBLIC_APP_URL}/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_OAUTH_GITHUB_ENABLED=false
