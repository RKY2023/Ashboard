# MongoDB Connection URLs
# Get these from your MongoDB Atlas dashboard
# DO NOT commit actual credentials to git!
API_URL=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority&appName=AppName
API_URL2=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority&appName=AppName
