# MongoDB Connection
API_URL=mongodb+srv://username:password@cluster.mongodb.net/ashboard?retryWrites=true&w=majority

# JWT Secrets (generate secure random strings)
JWT_SECRET=your-jwt-secret-key-min-32-characters-long
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-min-32-chars

# Redis Connection (optional, for caching)
REDIS_URL=redis://localhost:6379

# MQTT Broker (for IoT devices)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Resend (transactional email — password resets, etc.)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Ashboard <noreply@yourdomain.com>
